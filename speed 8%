local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

local Config = {
    Enabled = true,
    SpeedBoost = 8, -- Persentase speed boost (8%)
    Radius = 9999    -- Radius deteksi survivor lain (9999 = seluruh map)
}

local State = {
    LastBoostTime = 0,
    OriginalSpeed = nil,
    InCutscene = false,
    Running = true
}


local function unlockPerk()
    local playerData = LocalPlayer:FindFirstChild("Data")
    if not playerData then return end
    
    local perksData = playerData:FindFirstChild("Perks")
    if not perksData then return end
    
    for i = 1, 4 do
        local slot = perksData:FindFirstChild("Slot" .. i)
        if slot and slot:IsA("StringValue") then
            if slot.Value == "" or slot.Value == nil or slot.Value == "None" then
                slot.Value = "We're Stronger Together"
                break
            end
        end
    end
end


local function modifyPerkModule()
    local perksFolder = ReplicatedStorage:FindFirstChild("Perks")
    if not perksFolder then return end
    
    local perkModule = perksFolder:FindFirstChild("We're Stronger Together")
    if perkModule and perkModule:IsA("ModuleScript") then
        local success, env = pcall(function()
            return getfenv(perkModule)
        end)
        if success and env then
            env.radius = Config.Radius
            env.Range = Config.Radius
            env.distance = Config.Radius
            env.speedBonus = Config.SpeedBoost / 100
            env.boost = Config.SpeedBoost / 100
            env.multiplier = 1 + (Config.SpeedBoost / 100)
        end
    end
end



local function activatePerk()
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if not remotes then return end
    
    local perkEvent = remotes:FindFirstChild("PerkEvent")
    if perkEvent and perkEvent:IsA("RemoteEvent") then
        pcall(function()
            perkEvent:FireServer("We're Stronger Together")
            perkEvent:FireServer("We're Stronger Together", true)
        end)
    end
end


local function removeCooldown()
    local playerData = LocalPlayer:FindFirstChild("Data")
    if playerData then
        local cooldowns = playerData:FindFirstChild("Cooldowns")
        if cooldowns then
            local perkCD = cooldowns:FindFirstChild("We're Stronger Together")
            if perkCD and perkCD:IsA("NumberValue") then
                perkCD.Value = 0
            end
        end
    end
    
    local function clearCD(instance)
        if instance:IsA("NumberValue") and instance.Name:lower():find("cooldown") then
            instance.Value = 0
        end
        for _, child in ipairs(instance:GetChildren()) do
            clearCD(child)
        end
    end
    
    clearCD(ReplicatedStorage)
    clearCD(LocalPlayer)
end


local function getNearestSurvivor()
    local char = LocalPlayer.Character
    if not char then return nil, math.huge end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil, math.huge end
    
    local nearestDist = math.huge
    local nearestSurvivor = nil
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Team and player.Team.Name == "Survivors" then
            local survivorChar = player.Character
            if survivorChar then
                local survivorRoot = survivorChar:FindFirstChild("HumanoidRootPart")
                if survivorRoot then
                    local dist = (survivorRoot.Position - root.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearestSurvivor = player
                    end
                end
            end
        end
    end
    
    return nearestSurvivor, nearestDist
end

local function applySpeedBoost()
    if State.InCutscene then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    if State.OriginalSpeed == nil then
        State.OriginalSpeed = hum.WalkSpeed
    end
    
    local _, dist = getNearestSurvivor()
    
    if Config.Enabled and dist <= Config.Radius then
        local bonus = Config.SpeedBoost / 100
        local newSpeed = State.OriginalSpeed + (State.OriginalSpeed * bonus)
        hum.WalkSpeed = newSpeed
    else
        hum.WalkSpeed = State.OriginalSpeed
    end
end


local function startMainLoop()
    spawn(function()
        while State.Running do
            if not State.InCutscene then
                applySpeedBoost()
            end
            task.wait(0.1)
        end
    end)
end


local function setupCutsceneDetection()
    local function checkCutscene()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if not playerGui then return end
        
        local function onDescendantAdded(descendant)
            local nameLower = descendant.Name:lower()
            
            if nameLower:find("cutscene") or 
               nameLower:find("cinematic") or 
               nameLower:find("transition") or
               nameLower:find("loading") or
               nameLower:find("black") or
               nameLower:find("fade") then
                
                State.InCutscene = true
                
                local waitTime = 0
                while waitTime < 5 do
                    local stillExists = descendant.Parent ~= nil
                    if not stillExists then break end
                    wait(0.5)
                    waitTime = waitTime + 0.5
                end
                
                State.InCutscene = false
                
                if Config.Enabled then
                    modifyPerkModule()
                    activatePerk()
                    removeCooldown()
                    State.OriginalSpeed = nil
                end
            end
        end
        
        playerGui.DescendantAdded:Connect(onDescendantAdded)
    end
    
    spawn(checkCutscene)
end


local function setupRespawnDetection()
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(1)
        State.OriginalSpeed = nil
        modifyPerkModule()
        activatePerk()
        removeCooldown()
    end)
end


local function setupGuiDetection()
    local function checkGui()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
        end
    end
    
    LocalPlayer:GetPropertyChangedSignal("PlayerGui"):Connect(checkGui)
    checkGui()
end


local function reloadSystem()
    if not Config.Enabled then return end
    modifyPerkModule()
    activatePerk()
    removeCooldown()
    State.OriginalSpeed = nil
end


unlockPerk()
modifyPerkModule()
activatePerk()
removeCooldown()
startMainLoop()
setupCutsceneDetection()
setupRespawnDetection()
setupGuiDetection()


_G.togglePerk = function()
    Config.Enabled = not Config.Enabled
    if not Config.Enabled then
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum and State.OriginalSpeed then
            hum.WalkSpeed = State.OriginalSpeed
        end
    else
        reloadSystem()
    end
end

_G.setPerkSpeed = function(percent)
    Config.SpeedBoost = percent
    modifyPerkModule()
    State.OriginalSpeed = nil
end

_G.setPerkRadius = function(radius)
    Config.Radius = radius
    modifyPerkModule()
end

_G.reloadPerk = reloadSystem
